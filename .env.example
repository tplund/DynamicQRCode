# Database (Neon PostgreSQL) — REQUIRED
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-random-string
NEXTAUTH_URL=http://localhost:3000

# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
AUTH_PASSWORD_HASH=$2b$12$...

# Mailjet (email)
MAILJET_API_KEY=
MAILJET_API_SECRET=
FROM_EMAIL=hello@getdynamicqrcode.com
NOTIFY_EMAIL=your-email@example.com

# LemonSqueezy (payments) — optional, enables paid plans
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_PRO_YEARLY=
LEMONSQUEEZY_VARIANT_BUSINESS=
LEMONSQUEEZY_VARIANT_BUSINESS_YEARLY=

# Sentry (error monitoring) — optional
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Analytics & Search Console — optional
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
